# ─────────────────────────────────────────────────────────────────────────────
# OTP Messenger — environment template
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# In production, inject these from a secrets manager (Vault, AWS SSM, etc.).
# ─────────────────────────────────────────────────────────────────────────────

# 256-bit application secret (Flask session signing + CSRF).
# Generate with:  python3 -c "import secrets; print(secrets.token_hex(32))"
# Must be identical across all Gunicorn workers and restarts.
SECRET_KEY=replace-with-a-64-char-hex-secret

# Runtime mode — keep 'production'.
FLASK_ENV=production

# Log verbosity (DEBUG|INFO|WARNING|ERROR).
LOG_LEVEL=INFO

# Shared rate-limit storage for the Flask-Limiter across worker processes.
# Defaults to in-process memory:// (nginx limit_req is the primary, shared gate).
# For a strictly correct multi-worker app-layer limit, point at Redis:
#   RATELIMIT_STORAGE_URI=redis://redis:6379/0
RATELIMIT_STORAGE_URI=memory://
